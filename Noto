local readyHoldTimer = 0

-- Cooldown event handler
if PetCooldownsUpdated then
    PetCooldownsUpdated.OnClientEvent:Connect(function(a, b)
        local lvlKey       = lvlSelectedMimic   and normGuid(lvlSelectedMimic)   or nil
        local nmKey        = nmSelectedMimic     and normGuid(nmSelectedMimic)    or nil

        local function tryExtract(a_, b_, key, isElephant)
            if a_ and b_ and normGuid(a_) == key then
                local s = pickSeconds(b_)
                if s ~= nil then
                    mimicRemain = s
                end
                return true
            end
            return false
        end

        -- Direct two-arg form
        if lvlKey     then tryExtract(a, b, lvlKey,       false) end
        if nmKey      then tryExtract(a, b, nmKey,        false) end

        -- Table form
        if type(a) == "table" and not b then
            for k, v in pairs(a) do
                local nk = normGuid(k)
                if nk == lvlKey or nk == nmKey then
                    local s = pickSeconds(v)
                    if s ~= nil then mimicRemain = s end
                end
            end
        end
    end)
end

-- Periodic cooldown poll
task.spawn(function()
    while true do
        if RequestPetCooldowns then
            pcall(function() RequestPetCooldowns:FireServer() end)
            if lvlSelectedMimic   then pcall(function() RequestPetCooldowns:FireServer(lvlSelectedMimic)   end) end
            if nmSelectedMimic    then pcall(function() RequestPetCooldowns:FireServer(nmSelectedMimic)    end) end
        end
        task.wait(POLL_SEC)
    end
end)

-- Get initial slot
currentSlot = getCurrentSlotFromService() or 1

--==============================================================--
-- MAIN LOOP
--==============================================================--
task.spawn(function()
    while true do
        task.wait(TICK_SEC)

        -- Decay cooldown timers
        if type(mimicRemain)    == "number" then mimicRemain    = math.max(0, mimicRemain    - TICK_SEC) end

        -- Real-time slot from DataService
        local realSlot = getCurrentSlotFromService()
        if realSlot then currentSlot = realSlot end

        -- Convert DataService slot to visual slot (2 and 3 are swapped)
        local visualSlot = currentSlot
        if currentSlot == 2 then visualSlot = 3
        elseif currentSlot == 3 then visualSlot = 2
        end

        local cdTxt   = mimicRemain and string.format("%.2fs", mimicRemain) or "—"
        local slotTxt = string.format("Slot %d", visualSlot)

        ---------------------------------------------------------------
        -- LEVELING V1 UI
        ---------------------------------------------------------------
        local lvlPetData     = getPetDataFromService(lvlSelectedLeveling)
        local lvlPetName     = lvlPetData and (lvlPetData.name ~= "" and lvlPetData.name or "—") or "—"
        local lvlPetType     = lvlPetData and lvlPetData.type or "—"
        local lvlPetAge      = lvlPetData and lvlPetData.age or 0
        local lvlPetMutation = lvlPetData and lvlPetData.mutation or "—"
        local lvlMutEmoji    = (lvlPetMutation == "Nightmare" and "🌙 " or lvlPetMutation == "Rainbow" and "🌈 " or lvlPetMutation == "Golden" and "✨ " or "")

        LvlInfoParagraph:SetDesc(string.format(
            "⏱ Cooldown: %s\n📍 Slot: %s\n🐾 Pet: %s\n🏷 Type: %s\n✨ Mutation: %s%s\n📊 Age: %d/%d\n📋 Queue: %s\n✅ Done: %d\n🔌 Equipped: %s\n⚡ Mode: %s",
            cdTxt, slotTxt, lvlPetName, lvlPetType,
            lvlMutEmoji, lvlPetMutation, lvlPetAge, lvlTargetLevel,
            (#lvlLevelingQueue > 0 and string.format("%d/%d", lvlCurrentQueueIndex, #lvlLevelingQueue) or "0/0"),
            #lvlCompletedPets,
            lvlPetEquipped and "✅ Yes" or "❌ No",
            lvlAutoEnabled and "🟢 ON" or "🔴 OFF"
        ))

        ---------------------------------------------------------------
        -- LEVELING V1 LOGIC
        ---------------------------------------------------------------
        if lvlAutoEnabled and lvlSelectedLeveling then
            if visualSlot == lvlLevelingSlot and not lvlPetEquipped then
                pcall(function()
                    PetsService:FireServer("EquipPet", lvlSelectedLeveling, CFrame.new())
                end)
                lvlPetEquipped = true
                WindUI:Notify({Title="🐾 Pet Equipped",Content=string.format("%s (%d/%d)", lvlPetName, lvlCurrentQueueIndex, #lvlLevelingQueue),Duration=3,Icon="plus-circle"})
            end
            if visualSlot == lvlMimicDilopSlot and lvlPetEquipped then
                pcall(function() PetsService:FireServer("UnequipPet", lvlSelectedLeveling) end)
                lvlPetEquipped = false
            end
            if lvlPetAge >= lvlTargetLevel then
                if lvlPetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", lvlSelectedLeveling) end)
                    lvlPetEquipped = false
                end
                WindUI:Notify({Title="✅ Level Complete!",Content=string.format("%s reached Level %d!", lvlPetName, lvlTargetLevel),Duration=5,Icon="check-circle"})
                sendWebhook("✅ Level Complete!", "Pet reached target level", 5763719, {
                    {name="🐾 Pet", value=lvlPetName, inline=true},
                    {name="🏷 Type", value=lvlPetType, inline=true},
                    {name="📊 Level", value=tostring(lvlTargetLevel), inline=true},
                })
                table.insert(lvlCompletedPets, lvlSelectedLeveling)
                if lvlCurrentQueueIndex < #lvlLevelingQueue then
                    lvlCurrentQueueIndex = lvlCurrentQueueIndex + 1
                    lvlSelectedLeveling  = lvlLevelingQueue[lvlCurrentQueueIndex]
                    local npd = getPetDataFromService(lvlSelectedLeveling)
                    local nName = npd and (npd.name ~= "" and npd.name or npd.type) or "Unknown"
                    WindUI:Notify({Title="🔄 Next Pet",Content=string.format("Now leveling: %s (%d/%d)", nName, lvlCurrentQueueIndex, #lvlLevelingQueue),Duration=5,Icon="arrow-right"})
                else
                    lvlAutoEnabled = false; LvlAutoToggle:Set(false)
                    WindUI:Notify({Title="🎉 ALL COMPLETE!",Content=string.format("All %d pets reached Level %d!", #lvlCompletedPets, lvlTargetLevel),Duration=15,Icon="award"})
                    sendWebhook("🎉 ALL COMPLETE!", "All pets leveled!", 5814783, {
                        {name="✅ Completed", value=string.format("%d pets", #lvlCompletedPets), inline=true},
                        {name="📊 Target", value=string.format("Level %d", lvlTargetLevel), inline=true},
                    })
                end
            end
        end

        ---------------------------------------------------------------
        -- LEVELING V2 UI
        ---------------------------------------------------------------
        local v2PetData     = getPetDataFromService(v2SelectedLeveling)
        local v2PetName     = v2PetData and (v2PetData.name ~= "" and v2PetData.name or "—") or "—"
        local v2PetType     = v2PetData and v2PetData.type or "—"
        local v2PetAge      = v2PetData and v2PetData.age or 0
        local v2PetMutation = v2PetData and v2PetData.mutation or "—"
        local v2MutEmoji    = (v2PetMutation == "Nightmare" and "🌙 " or v2PetMutation == "Rainbow" and "🌈 " or "")

        if V2InfoParagraph then
            V2InfoParagraph:SetDesc(string.format(
                "🍟 Triggers: %d\n📍 Slot: %s\n🐾 Pet: %s\n🏷 Type: %s\n✨ Mutation: %s%s\n📊 Age: %d/%d\n📋 Queue: %s\n✅ Done: %d\n🔌 Equipped: %s\n⚡ Mode: %s",
                v2TriggerCount, slotTxt, v2PetName, v2PetType,
                v2MutEmoji, v2PetMutation, v2PetAge, v2TargetLevel,
                (#v2LevelingQueue > 0 and string.format("%d/%d", v2CurrentQueueIndex, #v2LevelingQueue) or "0/0"),
                #v2CompletedPets,
                v2PetEquipped and "✅ Yes" or "❌ No",
                v2AutoEnabled and "🟢 ON" or "🔴 OFF"
            ))
        end

        ---------------------------------------------------------------
        -- LEVELING V2 LOGIC
        ---------------------------------------------------------------
        if v2AutoEnabled and v2SelectedLeveling and #v2LevelingQueue > 0 then
            local v2d = getPetDataFromService(v2SelectedLeveling)
            local v2Age  = v2d and v2d.age or 0
            local v2Name = v2d and (v2d.name ~= "" and v2d.name or v2d.type) or "Unknown"
            local v2Type = v2d and v2d.type or "Unknown"
            if not v2PetEquipped then
                pcall(function() PetsService:FireServer("EquipPet", v2SelectedLeveling) end)
                v2PetEquipped = true
            end
            if v2Age >= v2TargetLevel then
                if v2PetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", v2SelectedLeveling) end)
                    v2PetEquipped = false
                end
                WindUI:Notify({Title="✅ Level Complete!",Content=string.format("%s reached Level %d!", v2Name, v2Age),Duration=5,Icon="check-circle"})
                sendWebhook("✅ Level Complete!", "Pet reached target level", 5763719, {
                    {name="🐾 Pet", value=v2Name, inline=true},
                    {name="🍟 Triggers", value=tostring(v2TriggerCount), inline=true},
                })
                table.insert(v2CompletedPets, v2SelectedLeveling)
                if v2CurrentQueueIndex < #v2LevelingQueue then
                    v2CurrentQueueIndex = v2CurrentQueueIndex + 1
                    v2SelectedLeveling  = v2LevelingQueue[v2CurrentQueueIndex]
                    v2TriggerCount = 0
                    local npd = getPetDataFromService(v2SelectedLeveling)
                    local nName = npd and (npd.name ~= "" and npd.name or npd.type) or "Unknown"
                    WindUI:Notify({Title="🔄 Next Pet",Content=string.format("Now leveling: %s (%d/%d)", nName, v2CurrentQueueIndex, #v2LevelingQueue),Duration=5,Icon="arrow-right"})
                else
                    v2AutoEnabled = false; V2AutoToggle:Set(false)
                    WindUI:Notify({Title="🎉 ALL COMPLETE!",Content=string.format("All %d pets reached target level!", #v2CompletedPets),Duration=15,Icon="award"})
                end
            end
        end

        ---------------------------------------------------------------
        -- NIGHTMARE UI
        ---------------------------------------------------------------
        local petData     = getPetDataFromService(nmSelectedLeveling)
        local petName     = petData and (petData.name ~= "" and petData.name or "—") or "—"
        local petType     = petData and petData.type or "—"
        local petAge      = petData and petData.age or 0
        local petMutation = petData and petData.mutation or "—"
        local mutEmoji    = (petMutation == "Nightmare" and "🌙 " or petMutation == "Rainbow" and "🌈 " or "")

        NmInfoParagraph:SetDesc(string.format(
            "📍 Phase: %s\n⏱ Cooldown: %s\n📍 Slot: %s\n🐾 Pet: %s\n🏷 Type: %s\n✨ Mutation: %s%s\n📊 Age: %d/%d\n📋 Queue: %s\n✅ Done: %d\n🔌 Equipped: %s\n⚡ Mode: %s",
            nmPhase == "MUTATION" and "🌙 MUTATION" or "📈 LEVELING",
            cdTxt, slotTxt, petName, petType,
            mutEmoji, petMutation, petAge, targetLevel,
            (#levelingQueue > 0 and string.format("%d/%d", currentQueueIndex, #levelingQueue) or "0/0"),
            #nmCompletedPets,
            nmPetEquipped and "✅ Yes" or "❌ No",
            nmAutoEnabled and "🟢 ON" or "🔴 OFF"
        ))

        ---------------------------------------------------------------
        -- NIGHTMARE LOGIC - PHASE 1: LEVELING
        ---------------------------------------------------------------
        if nmPhase == "LEVELING" and nmAutoEnabled and nmSelectedLeveling then
            if visualSlot == nmLevelingSlot and not nmPetEquipped then
                pcall(function()
                    PetsService:FireServer("EquipPet", nmSelectedLeveling, CFrame.new())
                end)
                nmPetEquipped = true
                WindUI:Notify({Title="🐾 Pet Equipped",Content=string.format("%s (%d/%d) - Leveling", petName, currentQueueIndex, #levelingQueue),Duration=3,Icon="plus-circle"})
            end
            if visualSlot == nmMimicDilopSlot and nmPetEquipped then
                pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                nmPetEquipped = false
            end
            if petAge >= targetLevel then
                if nmPetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                    nmPetEquipped = false
                end
                nmPhase = "MUTATION"
                nmMutationChecked = false
                lastMutationResult = nil
                lastMutationName   = nil
                WindUI:Notify({Title="🌙 MUTATION PHASE",Content=string.format("%s reached Lvl %d! Going to mutation...", petName, targetLevel),Duration=5,Icon="moon"})
                task.wait(0.5)
                swapTo(visualToInternal(nmMutationSlot))
            end
        end

        ---------------------------------------------------------------
        -- NIGHTMARE LOGIC - PHASE 2: MUTATION
        ---------------------------------------------------------------
        if nmPhase == "MUTATION" and nmAutoEnabled and nmSelectedLeveling then
            if visualSlot ~= nmMutationSlot then
                swapTo(visualToInternal(nmMutationSlot))
            end
            if visualSlot == nmMutationSlot and not nmPetEquipped then
                pcall(function()
                    PetsService:FireServer("EquipPet", nmSelectedLeveling, CFrame.new())
                end)
                nmPetEquipped = true
                lastMutationResult = nil
                lastMutationName   = nil
                WindUI:Notify({Title="🐾 Mutation: Pet Equipped",Content="Waiting for Headless skill...",Duration=3,Icon="moon"})
            end
            if nmPetEquipped and lastMutationResult then
                task.wait(1)
                local fpd  = getPetDataFromService(nmSelectedLeveling)
                local fName = fpd and (fpd.name ~= "" and fpd.name or fpd.type) or "Unknown"
                if lastMutationResult == "Nightmare" then
                    WindUI:Notify({Title="🌙 NIGHTMARE GET!",Content=string.format("%s got Nightmare! Moving to next pet...", fName),Duration=8,Icon="check-circle"})
                    task.wait(1)
                    pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                    nmPetEquipped = false
                    lastMutationResult = nil; lastMutationName = nil
                    table.insert(nmCompletedPets, nmSelectedLeveling)
                    if currentQueueIndex < #levelingQueue then
                        currentQueueIndex  = currentQueueIndex + 1
                        nmSelectedLeveling = levelingQueue[currentQueueIndex]
                        nmPhase = "LEVELING"
                        local npd = getPetDataFromService(nmSelectedLeveling)
                        local nName = npd and (npd.name ~= "" and npd.name or npd.type) or "Unknown"
                        WindUI:Notify({Title="🔄 Next Pet!",Content=string.format("Now leveling: %s (%d/%d)", nName, currentQueueIndex, #levelingQueue),Duration=5,Icon="arrow-right"})
                        task.wait(1)
                        swapTo(visualToInternal(nmMimicDilopSlot))
                    else
                        nmAutoEnabled = false; NmAutoToggle:Set(false); nmPhase = "LEVELING"
                        WindUI:Notify({Title="🎉 ALL COMPLETE!",Content=string.format("All %d pets got Nightmare!", #nmCompletedPets),Duration=15,Icon="award"})
                    end
                else
                    WindUI:Notify({Title="❌ Wrong Mutation",Content=string.format("%s got %s, cleansing in 2s...", fName, lastMutationName or "Unknown"),Duration=5,Icon="x-circle"})
                    task.wait(2)
                    local ok, msg = applyCleansingShardToPet(nmSelectedLeveling)
                    if ok then
                        WindUI:Notify({Title="🧹 Cleansed!",Content=string.format("%s cleansed, back to leveling in 2s...", fName),Duration=5,Icon="refresh-cw"})
                        task.wait(2)
                        pcall(function() PetsService:FireServer("UnequipPet", nmSelectedLeveling) end)
                        nmPetEquipped = false
                        lastMutationResult = nil; lastMutationName = nil
                        nmPhase = "LEVELING"
                        task.wait(1)
                        swapTo(visualToInternal(nmMimicDilopSlot))
                    else
                        WindUI:Notify({Title="⚠️ Cleanse Failed",Content=msg,Duration=5,Icon="alert-triangle"})
                        lastMutationResult = nil; lastMutationName = nil
                    end
                end
            end
        end

        ---------------------------------------------------------------
        -- ELEPHANT METHOD UI
        ---------------------------------------------------------------
        local emPetData     = getPetDataFromService(em_SelectedLeveling)
        local emPetName     = emPetData and (emPetData.name ~= "" and emPetData.name or "—") or "—"
        local emPetType     = emPetData and emPetData.type or "—"
        local emPetAge      = emPetData and emPetData.age or 0
        local emPetMutation = emPetData and emPetData.mutation or "—"
        local emMutEmoji    = (emPetMutation == "Nightmare" and "🌙 " or emPetMutation == "Rainbow" and "🌈 " or "")

        if EmInfoParagraph then
            EmInfoParagraph:SetDesc(string.format(
                "🍟 Triggers: %d\n📍 Slot: %s\n🐾 Pet: %s\n🏷 Type: %s\n✨ Mutation: %s%s\n📊 Age: %d/%d\n📋 Queue: %s\n✅ Done: %d\n🔌 Equipped: %s\n⚡ Mode: %s",
                em_TriggerCount, slotTxt, emPetName, emPetType,
                emMutEmoji, emPetMutation, emPetAge, em_TargetLevel,
                (#em_LevelingQueue > 0 and string.format("%d/%d", em_CurrentQueueIndex, #em_LevelingQueue) or "0/0"),
                #em_CompletedPets,
                em_PetEquipped and "✅ Yes" or "❌ No",
                em_AutoEnabled and "🟢 ON" or "🔴 OFF"
            ))
        end

        ---------------------------------------------------------------
        -- ELEPHANT METHOD LOGIC
        ---------------------------------------------------------------
        if em_AutoEnabled and em_SelectedLeveling and #em_LevelingQueue > 0 then
            local emd  = getPetDataFromService(em_SelectedLeveling)
            local emAge  = emd and emd.age or 0
            local emName = emd and (emd.name ~= "" and emd.name or emd.type) or "Unknown"
            local emType = emd and emd.type or "Unknown"
            if not em_PetEquipped then
                pcall(function() PetsService:FireServer("EquipPet", em_SelectedLeveling) end)
                em_PetEquipped = true
            end
            if emAge >= em_TargetLevel then
                if em_PetEquipped then
                    pcall(function() PetsService:FireServer("UnequipPet", em_SelectedLeveling) end)
                    em_PetEquipped = false
                end
                WindUI:Notify({Title="✅ Level Complete!",Content=string.format("%s reached Level %d!", emName, emAge),Duration=5,Icon="check-circle"})
                sendWebhook("✅ Level Complete!", "Pet reached target level", 5763719, {
                    {name="🐾 Pet", value=emName, inline=true},
                    {name="🍟 Triggers", value=tostring(em_TriggerCount), inline=true},
                })
                table.insert(em_CompletedPets, em_SelectedLeveling)
                if em_CurrentQueueIndex < #em_LevelingQueue then
                    em_CurrentQueueIndex = em_CurrentQueueIndex + 1
                    em_SelectedLeveling  = em_LevelingQueue[em_CurrentQueueIndex]
                    em_TriggerCount = 0
                    local npd = getPetDataFromService(em_SelectedLeveling)
                    local nName = npd and (npd.name ~= "" and npd.name or npd.type) or "Unknown"
                    WindUI:Notify({Title="🔄 Next Pet",Content=string.format("Now leveling: %s (%d/%d)", nName, em_CurrentQueueIndex, #em_LevelingQueue),Duration=5,Icon="arrow-right"})
                else
                    em_AutoEnabled = false; EmAutoToggle:Set(false)
                    WindUI:Notify({Title="🎉 ALL COMPLETE!",Content=string.format("All %d pets reached target level!", #em_CompletedPets),Duration=15,Icon="award"})
                end
            end
        end

        ---------------------------------------------------------------
        -- AUTO SLOT SWITCHING (Mimic cooldown based)
        ---------------------------------------------------------------
        local isLvlActive = lvlAutoEnabled
        local isNmActive  = nmAutoEnabled  and nmPhase  == "LEVELING"

        if not isLvlActive and not isNmActive then
            readyHoldTimer = 0
        else
            local dilopSlot, levelSlot
            if isNmActive then
                dilopSlot = nmMimicDilopSlot; levelSlot = nmLevelingSlot
            else
                dilopSlot = lvlMimicDilopSlot; levelSlot = lvlLevelingSlot
            end

            if visualSlot == dilopSlot then
                if mimicRemain and mimicRemain <= READY_EPS then
                    readyHoldTimer = readyHoldTimer + TICK_SEC
                    if readyHoldTimer >= READY_HOLD_SEC then
                        swapTo(visualToInternal(levelSlot))
                        readyHoldTimer = 0
                    end
                else
                    readyHoldTimer = 0
                end
            elseif visualSlot == levelSlot then
                if mimicRemain and mimicRemain > READY_EPS then
                    swapTo(visualToInternal(dilopSlot))
                    readyHoldTimer = 0
                end
            end
        end
    end
end)


